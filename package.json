{
  "name": "cursor-sdk-pr-review-action",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Action that uses Cursor SDK cloud agents to review PRs, autofix safe findings, file Linear issues, and auto-approve low-complexity changes.",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "test": "node --import tsx/esm --test src/github-actor-login.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.10",
    "@octokit/rest": "^22.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
